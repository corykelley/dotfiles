theme = Adventure
font-family = CaskaydiaCove Nerd Font Mono
font-size = 18
macos-icon = holographic
window-inherit-working-directory = true

window-width = 100
window-height = 35
window-padding-x = 5
window-padding-y = 5

# Keep more scrollback (value is in bytes; ~50M is plenty for most use)
scrollback-limit = 52428800